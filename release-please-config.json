{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "sequential-calls": true,
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "tntstack-workspace",
      "components": [
        "tntstack",
        "native",
        "web",
        "@workspace/ui",
        "@workspace/i18n"
      ]
    }
  ],
  "pull-request-title-pattern": "release version: v${version}",
  "include-component-in-tag": false,
  "packages": {
    ".": {
      "changelog-path": "CHANGELOG.md",
      "release-type": "node",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "version-file": "package.json",
      "component": "tntstack",
      "package-name": "tntstack"
    },
    "apps/native": {
      "release-type": "node",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "skip-changelog": true,
      "version-file": "package.json",
      "component": "native",
      "extra-files": [
        {
          "type": "json",
          "path": "src-tauri/tauri.conf.json",
          "jsonpath": "$.version"
        },
        {
          "type": "toml",
          "path": "src-tauri/Cargo.toml",
          "jsonpath": "$.package.version"
        }
      ],
      "package-name": "native"
    },
    "apps/web": {
      "release-type": "node",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "skip-changelog": true,
      "version-file": "package.json",
      "component": "web",
      "package-name": "web"
    },
    "packages/ui": {
      "release-type": "node",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "skip-changelog": true,
      "version-file": "package.json",
      "component": "@workspace/ui",
      "package-name": "@workspace/ui"
    },
    "packages/i18n": {
      "release-type": "node",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "skip-changelog": true,
      "version-file": "package.json",
      "component": "@workspace/i18n",
      "package-name": "@workspace/i18n"
    },
    "packages/cli": {
      "release-type": "node",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "skip-changelog": false,
      "include-component-in-tag": true,
      "version-file": "package.json",
      "component": "@tntstack/create",
      "package-name": "@tntstack/create"
    }
  },
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance Improvements" },
    { "type": "deps", "section": "Dependencies" },
    { "type": "revert", "section": "Reverts" },
    { "type": "docs", "section": "Documentation" },
    { "type": "style", "section": "Styles" },
    { "type": "chore", "section": "Miscellaneous Chores", "hidden": true },
    { "type": "refactor", "section": "Code Refactoring" },
    { "type": "test", "section": "Tests" },
    { "type": "build", "section": "Build System" },
    { "type": "ci", "section": "Continuous Integration" }
  ]
}
